---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sổ tay sửa lỗi" description="Xem lại các câu hỏi đã trả lời sai để củng cố kiến thức.">
  <div class="mb-8 flex justify-between items-center">
    <div>
      <nav class="flex text-sm text-slate-500 mb-4" aria-label="Breadcrumb">
        <a href={import.meta.env.BASE_URL} class="hover:text-blue-600">Trang chủ</a>
        <span class="mx-2">/</span>
        <span class="text-slate-900 dark:text-slate-300 font-medium">Sổ tay sửa lỗi</span>
      </nav>
      <h1 class="text-3xl font-outfit font-bold tracking-tight">Sổ Tay Sửa Lỗi (Error Notebook)</h1>
      <p class="text-slate-650 dark:text-slate-400 mt-2">Nơi tổng hợp các câu hỏi bạn từng làm sai. Hãy luyện tập lại để không lặp lại lỗi cũ.</p>
    </div>
    <button id="clear-all-errors-btn" class="hidden px-4 py-2 text-xs font-semibold text-red-600 hover:text-red-750 border border-red-200 hover:bg-red-50 rounded-xl transition-all">
      Xóa toàn bộ
    </button>
  </div>

  <!-- Empty State -->
  <div id="empty-state" class="hidden p-8 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-center space-y-4">
    <div class="text-4xl">🌟</div>
    <h3 class="text-lg font-outfit font-bold">Sổ tay trống!</h3>
    <p class="text-slate-650 dark:text-slate-400 text-sm max-w-sm mx-auto">Tuyệt vời! Bạn chưa trả lời sai câu hỏi nào hoặc đã dọn dẹp sạch sổ tay. Hãy tiếp tục duy trì nhé.</p>
    <a href={`${import.meta.env.BASE_URL}practice`} class="inline-block px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-750 text-white text-xs font-semibold transition-all">Luyện đề ngay</a>
  </div>

  <!-- Errors List -->
  <div id="errors-list-container" class="space-y-6"></div>

  <script is:inline>
    const container = document.getElementById('errors-list-container');
    const emptyState = document.getElementById('empty-state');
    const clearBtn = document.getElementById('clear-all-errors-btn');

    function renderErrors() {
      const errors = JSON.parse(localStorage.getItem('error-notebook') || '[]');
      container.innerHTML = '';

      if (errors.length === 0) {
        emptyState.classList.remove('hidden');
        clearBtn.classList.add('hidden');
        return;
      }

      emptyState.classList.add('hidden');
      clearBtn.classList.remove('hidden');

      errors.forEach((err, idx) => {
        const div = document.createElement('div');
        div.className = "p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 space-y-4 relative shadow-sm";
        
        div.innerHTML = `
          <div class="flex items-center justify-between text-xs text-slate-450">
            <span>Sai lần đầu: ${new Date(err.timestamp).toLocaleDateString('vi-VN')}</span>
            <button class="text-red-500 hover:underline delete-single-error" data-id="${err.id}">Xóa câu này</button>
          </div>
          <h3 class="text-sm sm:text-base font-outfit font-bold text-slate-800 dark:text-slate-200">Q: ${err.question}</h3>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            ${err.options.map(opt => {
              let btnClass = "w-full text-left p-3 text-xs rounded-xl border border-slate-200 dark:border-slate-850 hover:bg-slate-50 dark:hover:bg-slate-950 font-sans";
              if (opt === err.answer) {
                btnClass = "w-full text-left p-3 text-xs rounded-xl border border-emerald-300 bg-emerald-50 text-emerald-800 dark:bg-emerald-950/20 dark:border-emerald-800 dark:text-emerald-300 font-semibold";
              } else if (opt === err.userChoice) {
                btnClass = "w-full text-left p-3 text-xs rounded-xl border border-red-300 bg-red-50 text-red-800 dark:bg-red-950/20 dark:border-red-800 dark:text-red-300 font-semibold";
              }
              return `<div class="${btnClass}">${opt}</div>`;
            }).join('')}
          </div>

          <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-950 border border-slate-150 dark:border-slate-850 text-xs">
            <p class="font-bold text-emerald-600 dark:text-emerald-400">Đáp án đúng: ${err.answer}</p>
            <p class="text-slate-600 dark:text-slate-400 mt-2">${err.explanation}</p>
            <p class="text-xs text-slate-400 mt-4">
              Nguồn bài học: <a href="${err.sourceUrl}" class="text-blue-500 hover:underline">${err.sourceTitle}</a>
            </p>
          </div>
        `;

        container.appendChild(div);
      });

      // Hook single delete buttons
      document.querySelectorAll('.delete-single-error').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.getAttribute('data-id');
          deleteSingle(id);
        });
      });
    }

    function deleteSingle(id) {
      let errors = JSON.parse(localStorage.getItem('error-notebook') || '[]');
      errors = errors.filter(e => e.id !== id);
      localStorage.setItem('error-notebook', JSON.stringify(errors));
      renderErrors();
    }

    clearBtn.addEventListener('click', () => {
      if (confirm('Bạn chắc chắn muốn xóa toàn bộ sổ tay sửa lỗi?')) {
        localStorage.removeItem('error-notebook');
        renderErrors();
      }
    });

    renderErrors();
  </script>
</Layout>
