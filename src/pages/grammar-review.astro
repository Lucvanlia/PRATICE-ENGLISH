      "unit-2": [
        { q: "She _____ in the sales department since 2018.", o: ["works", "is working", "has been working", "was working"], a: "has been working", e: "Từ nhận biết 'since 2018' (từ năm 2018 đến nay liên tục) kết hợp nhấn mạnh tính liên tục của hành động yêu cầu Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "It _____ for three hours and the streets are flooded now.", o: ["rained", "is raining", "has been raining", "was raining"], a: "has been raining", e: "Hành động mưa bắt đầu trong quá khứ kéo dài liên tục 3 tiếng đến hiện tại và để lại hậu quả 'đường bị ngập'. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "They _____ for the manager's final approval all morning.", o: ["wait", "are waiting", "have been waiting", "waited"], a: "have been waiting", e: "Cụm 'all morning' (suốt cả buổi sáng) nhấn mạnh thời gian kéo dài liên tục của hành động chờ đợi. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "How long _____ you _____ English at this learning center?", o: ["do/learn", "are/learning", "have/been learning", "did/learn"], a: "have/been learning", e: "Câu hỏi 'How long' (bao lâu rồi) dùng để hỏi về độ dài thời gian của hành động bắt đầu từ quá khứ đến nay. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>Have/Has + S + been + V-ing?</span>." },
        { q: "The IT technician _____ the server connection issue since 8:00 AM.", o: ["fixes", "is fixing", "has been fixing", "fixed"], a: "has been fixing", e: "Hành động sửa lỗi bắt đầu từ lúc 8h sáng kéo dài liên tục đến nay. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "I _____ for a suitable office space all week without success.", o: ["search", "am searching", "have been searching", "searched"], a: "have been searching", e: "Cụm 'all week' nhấn mạnh tính liên tục cả tuần. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "Our marketing team _____ customer purchasing trends for months.", o: ["analyzes", "is analyzing", "has been analyzing", "analyzed"], a: "has been analyzing", e: "Hành động phân tích kéo dài liên tục trong nhiều tháng qua. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "She is exhausted because she _____ overtime without any breaks.", o: ["works", "is working", "has been working", "worked"], a: "has been working", e: "Hậu quả hiện tại 'exhausted' (kiệt sức) xảy ra do một hành động kéo dài liên tục trước đó. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "We _____ with that creative agency for five years now.", o: ["cooperate", "are cooperating", "have been cooperating", "cooperated"], a: "have been cooperating", e: "Có trạng từ 'for five years now' chỉ độ dài liên tục 5 năm. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "The supplier _____ the delivery of raw materials repeatedly.", o: ["delays", "is delaying", "has been delaying", "delayed"], a: "has been delaying", e: "Hành động trì hoãn lặp đi lặp lại kéo dài từ quá khứ đến nay. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "Why _____ you _____ the monthly team briefings recently?", o: ["do/avoid", "are/avoiding", "have/been avoiding", "did/avoid"], a: "have/been avoiding", e: "Có trạng từ 'recently' (gần đây) chỉ hành động kéo dài liên tục gần đây. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>Have/Has + S + been + V-ing?</span>." },
        { q: "She _____ her presentation slides for the summit all afternoon.", o: ["practices", "is practicing", "has been practicing", "practiced"], a: "has been practicing", e: "Nhấn mạnh quá trình luyện tập diễn ra liên tục suốt buổi chiều. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "The price of steel _____ steadily since the trade policy changed.", o: ["rises", "is rising", "has been rising", "rose"], a: "has been rising", e: "Hành động tăng giá bắt đầu từ thời điểm chính sách thay đổi kéo dài liên tục đến nay. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "I _____ the market for a new supplier since last month.", o: ["research", "am researching", "have been researching", "researched"], a: "have been researching", e: "Bắt đầu nghiên cứu từ tháng trước đến nay chưa dừng lại. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "They _____ this plant for over twelve years.", o: ["operate", "are operating", "have been operating", "operated"], a: "have been operating", e: "Nhấn mạnh quá trình vận hành liên tục suốt 12 năm. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "He _____ emails to clients all morning, which is why his desk is messy.", o: ["sends", "is sending", "has been sending", "sent"], a: "has been sending", e: "Hành động gửi mail kéo dài liên tục cả buổi sáng dẫn đến hậu quả bàn làm việc bừa bộn ở hiện tại. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "The directors _____ the merger possibility since the CEO resigned.", o: ["discuss", "are discussing", "has been discussing", "have been discussing"], a: "have been discussing", e: "Chủ ngữ số nhiều 'directors' đi kèm hành động thảo luận liên tục từ khi CEO từ chức đến nay. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
        { q: "How long _____ the server _____ without interruption?", o: ["does/run", "is/running", "has/been running", "did/run"], a: "has/been running", e: "Hỏi về khoảng thời gian máy chủ chạy liên tục không ngừng nghỉ từ quá khứ đến nay. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>Have/Has + S + been + V-ing?</span>." },
        { q: "We _____ customer feedback reviews all week.", o: ["read", "are reading", "have been reading", "readed"], a: "have been reading", e: "Có trạng từ 'all week' chỉ hành động đọc đánh giá diễn ra liên tục cả tuần. Dùng Hiện tại hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + have/has + been + V-ing</span>." },
