    { eng: "You can submit the document online or send it by mail.", vie: "Bạn có thể nộp tài liệu trực tuyến hoặc gửi qua đường bưu điện." },
    { eng: "Because of the rain, the outdoor event was postponed.", vie: "Bởi vì trời mưa, sự kiện ngoài trời đã bị hoãn lại." },
    { eng: "Despite the high costs, the project was completed on time.", vie: "Bất chấp chi phí cao, dự án vẫn được hoàn thành đúng hạn." },
    { eng: "We will wait here until the courier delivers the package.", vie: "Chúng tôi sẽ đợi ở đây cho đến khi nhân viên giao hàng chuyển bưu kiện." },
    { eng: "Unless we cut down expenses, we will go over budget.", vie: "Trừ khi chúng ta cắt giảm chi phí, nếu không chúng ta sẽ vượt ngân sách." },
    { eng: "He worked overtime so that the software could launch on time.", vie: "Anh ấy đã làm việc tăng ca để phần mềm có thể ra mắt đúng hạn." },
    { eng: "As long as you follow the rules, you won't have issues.", vie: "Miễn là bạn tuân thủ các quy tắc, bạn sẽ không gặp rắc rối." },
    { eng: "In spite of the traffic, she arrived at the lobby early.", vie: "Mặc dù kẹt xe, cô ấy đã đến sảnh lễ tân sớm." },
    { eng: "The company expanded its marketing team since sales were low.", vie: "Công ty đã mở rộng đội ngũ tiếp thị vì doanh số bán hàng thấp." },
    { eng: "Both the CEO and the CFO approved the audit findings.", vie: "Cả Giám đốc điều hành và Giám đốc tài chính đều duyệt kết quả kiểm toán." }
  ],
  "unit-14": [
    { eng: "If you heat water to 100 degrees, it boils.", vie: "Nếu bạn đun nước đến 100 độ, nó sẽ sôi. (Câu điều kiện loại 0)" },
    { eng: "If the supplier confirms today, we will place the order.", vie: "Nếu nhà cung cấp xác nhận hôm nay, chúng tôi sẽ đặt hàng. (Loại 1)" },
    { eng: "If we had more budget, we would hire an assistant developer.", vie: "Nếu chúng ta có thêm ngân sách, chúng ta sẽ thuê một trợ lý lập trình. (Loại 2)" },
    { eng: "If she had reviewed the contract, she would have noticed the error.", vie: "Nếu cô ấy đã xem xét hợp đồng, cô ấy đã nhận ra lỗi. (Loại 3)" },
    { eng: "If the flight is delayed, the schedule will be changed.", vie: "Nếu chuyến bay bị trễ, lịch trình sẽ bị thay đổi." },
    { eng: "If I were the director, I would invest in new servers.", vie: "Nếu tôi là giám đốc, tôi sẽ đầu tư vào các máy chủ mới." },
    { eng: "If they had run tests, they would have found the software bug.", vie: "Nếu họ đã chạy thử nghiệm, họ đã tìm thấy lỗi phần mềm." },
    { eng: "If you have any questions, please contact the front desk.", vie: "Nếu bạn có bất kỳ câu hỏi nào, vui lòng liên hệ bàn lễ tân." },
    { eng: "If she gets the promotion, she will relocate to Seoul.", vie: "Nếu cô ấy được thăng chức, cô ấy sẽ chuyển đến Seoul." },
    { eng: "If he worked harder, he would achieve his sales target.", vie: "Nếu anh ấy làm việc chăm chỉ hơn, anh ấy sẽ đạt được mục tiêu doanh số." },
    { eng: "If the client had rejected the proposal, we would have lost the deal.", vie: "Nếu khách hàng từ chối đề xuất, chúng ta đã mất hợp đồng." },
    { eng: "If you mix blue and yellow, you get green.", vie: "Nếu bạn trộn màu xanh dương và màu vàng, bạn sẽ được màu xanh lá cây." },
    { eng: "If we don't reduce costs, the business will suffer loss.", vie: "Nếu chúng ta không giảm chi phí, doanh nghiệp sẽ chịu tổn thất." },
    { eng: "If I were you, I would back up all files immediately.", vie: "Nếu tôi là bạn, tôi sẽ sao lưu tất cả các tệp ngay lập tức." },
    { eng: "If they had signed earlier, the shipment would have arrived yesterday.", vie: "Nếu họ đã ký sớm hơn, lô hàng đã có thể đến vào ngày hôm qua." },
    { eng: "If the alarm goes off, security guards patrol the area.", vie: "Nếu chuông báo động reo, nhân viên bảo vệ sẽ tuần tra khu vực." },
    { eng: "If we receive the visa on time, we will travel next week.", vie: "Nếu chúng tôi nhận được thị thực đúng hạn, chúng tôi sẽ đi vào tuần tới." },
    { eng: "If the factory had green standards, buyers would purchase more.", vie: "Nếu nhà máy có tiêu chuẩn xanh, người mua sẽ mua nhiều hơn." },
    { eng: "If they had updated the site, users would not have complained.", vie: "Nếu họ đã cập nhật trang web, người dùng đã không phàn nàn." },
    { eng: "If she submits the draft today, I will review it tonight.", vie: "Nếu cô ấy nộp bản thảo hôm nay, tôi sẽ xem xét nó tối nay." }
  ]
};
---

<Layout title="Tổng ôn công thức & 20 ví dụ" description="Tóm tắt công thức ngữ pháp kèm 20 câu ví dụ song ngữ Anh-Việt cho 14 chủ điểm TOEIC.">
  <div class="mb-8">
    <nav class="flex text-sm text-slate-500 mb-4" aria-label="Breadcrumb">
      <a href={import.meta.env.BASE_URL} class="hover:text-blue-600">Trang chủ</a>
      <span class="mx-2">/</span>
      <span class="text-slate-900 dark:text-slate-300 font-medium">Tóm tắt công thức</span>
    </nav>
    <h1 class="text-3xl font-outfit font-bold tracking-tight">Tổng Ôn & Tóm Tắt Ngữ Pháp</h1>
    <p class="text-slate-650 dark:text-slate-400 mt-2">Phân rõ tiếng Việt, cấu trúc công thức và 20 câu ví dụ thực tế cho mỗi bài học.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
    <!-- Sidebar Navigation -->
    <div class="lg:col-span-1 space-y-2 lg:sticky lg:top-24 h-fit max-h-[80vh] overflow-y-auto pr-2 custom-scrollbar">
      <h3 class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider px-3 mb-3">Danh sách bài học</h3>
      {grammarLessons.map((lesson) => (
        <button 
          class="w-full text-left px-3 py-2 rounded-xl text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800 transition-all truncate unit-nav-btn" 
          data-target={lesson.id.replace(/\.mdx?$/, '')}
        >
          {lesson.data.title}
        </button>
      ))}
    </div>

    <!-- Central Detailed Review Card -->
    <div class="lg:col-span-3 space-y-8">
      {grammarLessons.map((lesson) => {
        const idClean = lesson.id.replace(/\.mdx?$/, '');
        const formulas = lesson.data.formulas || [];
        const sentences = sentenceData[idClean] || [];

        return (
          <div id={`content-${idClean}`} class="unit-content-section p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm space-y-6 hidden">
            <!-- Header -->
            <div>
              <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 dark:bg-blue-950/30 dark:text-blue-300 mb-3 border border-blue-200 dark:border-blue-800/30">
                Module {lesson.data.module}
              </div>
              <h2 class="text-2xl sm:text-3xl font-outfit font-bold">{lesson.data.title}</h2>
              <p class="text-slate-650 dark:text-slate-400 text-sm mt-2">{lesson.data.objective}</p>
            </div>

            <hr class="border-slate-150 dark:border-slate-800" />

            <!-- Formulas -->
            {formulas.length > 0 && (
              <div class="space-y-3">
                <h3 class="text-lg font-outfit font-bold flex items-center gap-2">
                  <span>📐</span> Công thức cốt lõi
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  {formulas.map(f => (
                    <div class="p-4 rounded-xl bg-blue-50/50 dark:bg-blue-950/10 border border-blue-100 dark:border-blue-900/20 space-y-1">
                      <span class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider">{f.label}</span>
                      <p class="font-mono font-bold text-slate-800 dark:text-slate-200 text-sm sm:text-base">{f.structure}</p>
                      <p class="text-xs text-slate-500 dark:text-slate-400 italic">Ex: {f.example}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <!-- Usage Summary in Vietnamese -->
            <div class="space-y-3">
              <h3 class="text-lg font-outfit font-bold flex items-center gap-2">
                <span>💡</span> Cách dùng & Dấu hiệu nhận biết
              </h3>
              <div class="p-5 rounded-xl bg-slate-50 dark:bg-slate-950 border border-slate-150 dark:border-slate-850 space-y-3 text-sm text-slate-700 dark:text-slate-300">
                <p>{lesson.data.summary}</p>
                <div class="space-y-2">
                  <p class="font-bold text-xs uppercase tracking-wider text-slate-500">Mẹo ghi nhớ từ chuyên gia:</p>
                  <ul class="list-disc pl-5 space-y-1.5 text-xs sm:text-sm">
                    {lesson.data.memoryTips.map(tip => (
                      <li>{tip}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>

            <!-- 20 Examples Section -->
            <div class="space-y-4">
              <h3 class="text-lg font-outfit font-bold flex items-center gap-2">
                <span>📚</span> 20 câu ví dụ thực tế (Anh - Việt)
              </h3>
              <div class="space-y-3 max-h-[500px] overflow-y-auto pr-2 border border-slate-100 dark:border-slate-850 rounded-xl p-4 bg-slate-50/30 dark:bg-slate-950/20 custom-scrollbar">
                {sentences.map((s, idx) => (
                  <div class="p-3 rounded-lg bg-white dark:bg-slate-900 border border-slate-150 dark:border-slate-800 space-y-1 text-xs sm:text-sm shadow-sm">
                    <div class="flex items-start gap-2">
                      <span class="font-bold text-blue-600 dark:text-blue-400 min-w-[20px]">{idx + 1}.</span>
                      <div class="space-y-0.5">
                        <p class="font-semibold text-slate-800 dark:text-slate-200">EN: {s.eng}</p>
                        <p class="text-slate-655 dark:text-slate-400">VI: {s.vie}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            
            <!-- Details button -->
            <div class="flex justify-end pt-2">
              <a href={`${import.meta.env.BASE_URL}grammar/${idClean}`} class="px-5 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-750 text-white text-xs font-semibold transition-all">
                Đến trang chi tiết bài học & Trắc nghiệm
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Interactive page script -->
  <script is:inline>
    const navButtons = document.querySelectorAll('.unit-nav-btn');
    const contentSections = document.querySelectorAll('.unit-content-section');

    function selectUnit(unitId) {
      // Hide all sections
      contentSections.forEach(section => {
        section.classList.add('hidden');
      });

      // Show targeted section
      const targetSection = document.getElementById(`content-${unitId}`);
      if (targetSection) {
        targetSection.classList.remove('hidden');
      }

      // Highlight active nav button
      navButtons.forEach(btn => {
        if (btn.getAttribute('data-target') === unitId) {
          btn.classList.remove('text-slate-700', 'dark:text-slate-300', 'hover:bg-slate-100', 'dark:hover:bg-slate-800');
          btn.classList.add('bg-blue-50', 'text-blue-700', 'dark:bg-blue-950/40', 'dark:text-blue-300', 'font-bold');
        } else {
          btn.classList.add('text-slate-700', 'dark:text-slate-300', 'hover:bg-slate-100', 'dark:hover:bg-slate-800');
          btn.classList.remove('bg-blue-50', 'text-blue-700', 'dark:bg-blue-950/40', 'dark:text-blue-300', 'font-bold');
        }
      });

      // Save preference to localStorage
      localStorage.setItem('selected-review-unit', unitId);
    }

    navButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-target');
        selectUnit(target);
      });
    });

    // Restore or default to unit-1
    const storedUnit = localStorage.getItem('selected-review-unit') || 'unit-1';
    selectUnit(storedUnit);
  </script>

  <style>
    .custom-scrollbar::-webkit-scrollbar {
      width: 5px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(100, 116, 139, 0.2);
      border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: rgba(100, 116, 139, 0.4);
    }
  </style>
</Layout>
