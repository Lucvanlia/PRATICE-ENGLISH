---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const grammarLessons = await getCollection('grammar');

// 20 rich sample sentences per grammar unit
const sentenceData = {
  "unit-1": [
    { eng: "The marketing director attends the weekly sales meeting every Monday.", vie: "Giám đốc tiếp thị tham dự cuộc họp bán hàng hàng tuần vào mỗi thứ Hai." },
    { eng: "We are currently upgrading our customer relationship management software.", vie: "Chúng tôi hiện đang nâng cấp phần mềm quản lý quan hệ khách hàng." },
    { eng: "The new flight to Singapore departs at 9:00 AM sharp tomorrow.", vie: "Chuyến bay mới đi Singapore khởi hành lúc đúng 9 giờ sáng mai." },
    { eng: "Water boils at 100 degrees Celsius under normal pressure.", vie: "Nước sôi ở 100 độ C dưới áp suất bình thường." },
