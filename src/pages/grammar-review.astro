        { q: "The system crashed because the team _____ enough testing beforehand.", o: ["didn't run", "had not run", "has not run", "was not running"], a: "had not run", e: "Hành động không chạy thử nghiệm xảy ra trước khi hệ thống bị sập. Dùng Quá khứ hoàn thành: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + not + V3/ed</span>." },
        { q: "By last Friday, she _____ all the required safety certifications.", o: ["submitted", "had submitted", "was submitting", "has submitted"], a: "had submitted", e: "Cụm thời gian 'By + mốc thời gian quá khứ' (trước thứ Sáu tuần trước) yêu cầu dùng Quá khứ hoàn thành: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + V3/ed</span>." },
        { q: "The programmer _____ code since morning before he finally took a break.", o: ["typed", "had been typing", "was typing", "has been typing"], a: "had been typing", e: "Nhấn mạnh quá trình gõ code liên tục bắt đầu từ sáng cho đến trước khi anh ấy nghỉ ngơi. Dùng Quá khứ hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + been + V-ing</span>." },
        { q: "They _____ on the venue before I could make any alternative suggestions.", o: ["already decided", "had already decided", "were already deciding", "have already decided"], a: "had already decided", e: "Quyết định địa điểm họp xảy ra trước khi tôi đưa ra gợi ý. Dùng Quá khứ hoàn thành: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + already + V3/ed</span>." },
        { q: "_____ you _____ the regional director before the annual summit took place?", o: ["Did/meet", "Had/met", "Were/meeting", "Have/met"], a: "Had/met", e: "Hỏi về trải nghiệm đã xảy ra hay chưa trước một mốc thời gian quá khứ. Dùng Quá khứ hoàn thành thể nghi vấn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>Had + S + V3/ed?</span>." },
        { q: "He was promoted because he _____ all of his quarterly sales targets.", o: ["achieved", "had achieved", "has achieved", "was achieving"], a: "had achieved", e: "Hành động đạt mục tiêu doanh số xảy ra trước, thăng chức xảy ra sau. Dùng Quá khứ hoàn thành: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + V3/ed</span>." },
        { q: "The market researchers _____ consumer trends for years before publishing findings.", o: ["researched", "had been researching", "were researching", "have been researching"], a: "had been researching", e: "Hành động nghiên cứu liên tục kéo dài nhiều năm trước khi công bố. Dùng Quá khứ hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + been + V-ing</span>." },
        { q: "By the time the training class ended, the trainees _____ the core concepts.", o: ["mastered", "had mastered", "were mastering", "have mastered"], a: "had mastered", e: "Cấu trúc 'By the time + S + V2/ed, S + had + V3/ed'. Chọn Quá khứ hoàn thành: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>had mastered</span>." },
        { q: "We _____ a shipping delay, so we had prepared a backup courier.", o: ["expected", "had expected", "were expecting", "have expected"], a: "had expected", e: "Kỳ vọng sự chậm trễ xảy ra trước khi chuẩn bị kế hoạch dự phòng. Dùng Quá khứ hoàn thành: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + V3/ed</span>." },
        { q: "The firm _____ money for months before the new director took office.", o: ["lost", "had been losing", "was losing", "has been losing"], a: "had been losing", e: "Hành động thua lỗ kéo dài liên tục hàng tháng trước mốc giám đốc nhậm chức. Dùng Quá khứ hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + been + V-ing</span>." },
        { q: "She _____ the report on time, so she received a warning yesterday.", o: ["didn't submit", "had not submitted", "has not submitted", "was not submitting"], a: "had not submitted", e: "Hành động không nộp báo cáo xảy ra trước thời điểm nhận cảnh cáo ngày hôm qua. Dùng Quá khứ hoàn thành: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + not + V3/ed</span>." },
        { q: "They _____ for the cargo flight for two weeks when it finally arrived.", o: ["waited", "had been waiting", "were waiting", "have been waiting"], a: "had been waiting", e: "Hành động chờ đợi hàng kéo dài liên tục 2 tuần trước khi nó đến. Dùng Quá khứ hoàn thành tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + been + V-ing</span>." },
        { q: "He suddenly realized he _____ the presentation flash drive at home.", o: ["forgot", "had forgotten", "was forgetting", "has forgotten"], a: "had forgotten", e: "Hành động để quên flash drive xảy ra trước thời điểm nhận ra. Dùng Quá khứ hoàn thành: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + V3/ed</span>." },
        { q: "By 2020, our brand _____ three regional offices in Europe.", o: ["established", "had established", "was establishing", "has established"], a: "had established", e: "Trước mốc thời gian quá khứ 'By 2020', dùng Quá khứ hoàn thành: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + had + V3/ed</span>." }
      ]
    };

    const navButtons = document.querySelectorAll('.unit-nav-btn');
    const contentSections = document.querySelectorAll('.unit-content-section');

    function selectUnit(unitId) {
      contentSections.forEach(section => {
        section.classList.add('hidden');
      });

      const targetSection = document.getElementById(`content-${unitId}`);
      if (targetSection) {
        targetSection.classList.remove('hidden');
      }

      navButtons.forEach(btn => {
        if (btn.getAttribute('data-target') === unitId) {
          btn.classList.remove('text-slate-700', 'dark:text-slate-300', 'hover:bg-slate-100', 'dark:hover:bg-slate-800');
          btn.classList.add('bg-blue-50', 'text-blue-700', 'dark:bg-blue-950/40', 'dark:text-blue-300', 'font-bold');
        } else {
          btn.classList.add('text-slate-700', 'dark:text-slate-300', 'hover:bg-slate-100', 'dark:hover:bg-slate-800');
          btn.classList.remove('bg-blue-50', 'text-blue-700', 'dark:bg-blue-950/40', 'dark:text-blue-300', 'font-bold');
        }
      });

      localStorage.setItem('selected-review-unit', unitId);
    }

    navButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-target');
        selectUnit(target);
      });
    });

    const storedUnit = localStorage.getItem('selected-review-unit') || 'unit-1';
    selectUnit(storedUnit);

    // Modal Quiz Logic
    const quizModal = document.getElementById('quiz-modal');
    const closeModalBtn = document.getElementById('close-modal-btn');
    const startQuizBtns = document.querySelectorAll('.start-review-quiz-btn');
    
    const modalQuizTitle = document.getElementById('modal-quiz-title');
    const modalProgressText = document.getElementById('modal-progress-text');
    const modalScoreText = document.getElementById('modal-score-text');
    const modalProgressBar = document.getElementById('modal-progress-bar');
    const modalQuestionText = document.getElementById('modal-question-text');
    const modalOptionsContainer = document.getElementById('modal-options-container');
    const modalExplanationCard = document.getElementById('modal-explanation-card');
    const modalCorrectLabel = document.getElementById('modal-correct-label');
    const modalExplanationText = document.getElementById('modal-explanation-text');
    const modalNextBtn = document.getElementById('modal-next-btn');
    const modalFinishBtn = document.getElementById('modal-finish-btn');

    let activeQuizQuestions = [];
    let currentQuizIndex = 0;
    let currentQuizScore = 0;

    function openQuiz(unitId, unitTitle) {
      const questions = reviewQuestionsData[unitId];
      if (!questions || questions.length === 0) {
        alert("Hiện tại chưa có bộ câu hỏi ôn tập đầy đủ cho bài học này. Vui lòng thử lại sau!");
        return;
      }
      
      activeQuizQuestions = questions;
      currentQuizIndex = 0;
      currentQuizScore = 0;
      modalQuizTitle.textContent = `Ôn tập: ${unitTitle}`;
      
      quizModal.classList.remove('hidden');
      renderQuizQuestion();
    }

    function renderQuizQuestion() {
      modalExplanationCard.classList.add('hidden');
      modalNextBtn.classList.add('hidden');
      modalFinishBtn.classList.add('hidden');

      const total = activeQuizQuestions.length;
      modalProgressText.textContent = `Câu hỏi ${currentQuizIndex + 1} / ${total}`;
      modalScoreText.textContent = `Đúng: ${currentQuizScore}`;
      modalProgressBar.style.width = `${((currentQuizIndex) / total) * 100}%`;

      const q = activeQuizQuestions[currentQuizIndex];
      modalQuestionText.textContent = q.q;

      modalOptionsContainer.innerHTML = '';
      q.o.forEach(opt => {
        const btn = document.createElement('button');
        btn.className = "w-full text-left p-3 text-xs sm:text-sm rounded-xl border border-slate-200 dark:border-slate-800 hover:border-blue-500 hover:bg-blue-50/10 transition-all font-sans";
        btn.textContent = opt;
        btn.addEventListener('click', () => handleQuizSelection(btn, opt, q));
        modalOptionsContainer.appendChild(btn);
      });
    }

    function handleQuizSelection(selectedBtn, selectedOption, q) {
      const buttons = modalOptionsContainer.querySelectorAll('button');
      buttons.forEach(btn => {
        btn.disabled = true;
        if (btn.textContent === q.a) {
          btn.className = "w-full text-left p-3 text-xs sm:text-sm rounded-xl border border-emerald-500 bg-emerald-50 text-emerald-800 dark:bg-emerald-950/20 dark:border-emerald-800 dark:text-emerald-300 font-semibold";
        }
      });

      if (selectedOption === q.a) {
        currentQuizScore++;
        selectedBtn.className = "w-full text-left p-3 text-xs sm:text-sm rounded-xl border border-emerald-500 bg-emerald-50 text-emerald-800 dark:bg-emerald-950/20 dark:border-emerald-800 dark:text-emerald-300 font-semibold";
      } else {
        selectedBtn.className = "w-full text-left p-3 text-xs sm:text-sm rounded-xl border border-red-500 bg-red-50 text-red-800 dark:bg-red-950/20 dark:border-red-800 dark:text-red-300 font-semibold";
      }

      modalCorrectLabel.textContent = `Đáp án đúng: ${q.a}`;
      modalExplanationText.innerHTML = q.e;
      modalExplanationCard.classList.remove('hidden');

      if (currentQuizIndex < activeQuizQuestions.length - 1) {
        modalNextBtn.classList.remove('hidden');
      } else {
        modalFinishBtn.classList.remove('hidden');
      }
    }

    startQuizBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const unitId = btn.getAttribute('data-unit');
        const unitTitle = btn.getAttribute('data-title');
        openQuiz(unitId, unitTitle);
      });
    });

    closeModalBtn.addEventListener('click', () => {
      quizModal.classList.add('hidden');
    });

    modalNextBtn.addEventListener('click', () => {
      currentQuizIndex++;
      renderQuizQuestion();
    });

    modalFinishBtn.addEventListener('click', () => {
      alert(`Chúc mừng bạn đã hoàn thành bài ôn tập! Kết quả: ${currentQuizScore} / ${activeQuizQuestions.length} câu đúng.`);
      quizModal.classList.add('hidden');
    });
  </script>

