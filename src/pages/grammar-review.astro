  "unit-12": [
    { eng: "Everyone in the marketing department attended the briefing.", vie: "Mọi người ở bộ phận tiếp thị đã tham dự buổi họp ngắn." },
    { eng: "Someone needs to respond to this customer query immediately.", vie: "Ai đó cần phải trả lời câu hỏi của khách hàng này ngay lập tức." },
