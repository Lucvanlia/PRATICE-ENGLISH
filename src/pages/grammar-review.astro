    { eng: "You can submit the document online or send it by mail.", vie: "Bạn có thể nộp tài liệu trực tuyến hoặc gửi qua đường bưu điện." },
    { eng: "Because of the rain, the outdoor event was postponed.", vie: "Bởi vì trời mưa, sự kiện ngoài trời đã bị hoãn lại." },
    { eng: "Despite the high costs, the project was completed on time.", vie: "Bất chấp chi phí cao, dự án vẫn được hoàn thành đúng hạn." },
    { eng: "We will wait here until the courier delivers the package.", vie: "Chúng tôi sẽ đợi ở đây cho đến khi nhân viên giao hàng chuyển bưu kiện." },
    { eng: "Unless we cut down expenses, we will go over budget.", vie: "Trừ khi chúng ta cắt giảm chi phí, nếu không chúng ta sẽ vượt ngân sách." },
    { eng: "He worked overtime so that the software could launch on time.", vie: "Anh ấy đã làm việc tăng ca để phần mềm có thể ra mắt đúng hạn." },
    { eng: "As long as you follow the rules, you won't have issues.", vie: "Miễn là bạn tuân thủ các quy tắc, bạn sẽ không gặp rắc rối." },
    { eng: "In spite of the traffic, she arrived at the lobby early.", vie: "Mặc dù kẹt xe, cô ấy đã đến sảnh lễ tân sớm." },
    { eng: "The company expanded its marketing team since sales were low.", vie: "Công ty đã mở rộng đội ngũ tiếp thị vì doanh số bán hàng thấp." },
    { eng: "Both the CEO and the CFO approved the audit findings.", vie: "Cả Giám đốc điều hành và Giám đốc tài chính đều duyệt kết quả kiểm toán." }
  ],
  "unit-14": [
    { eng: "If you heat water to 100 degrees, it boils.", vie: "Nếu bạn đun nước đến 100 độ, nó sẽ sôi. (Câu điều kiện loại 0)" },
    { eng: "If the supplier confirms today, we will place the order.", vie: "Nếu nhà cung cấp xác nhận hôm nay, chúng tôi sẽ đặt hàng. (Loại 1)" },
    { eng: "If we had more budget, we would hire an assistant developer.", vie: "Nếu chúng ta có thêm ngân sách, chúng ta sẽ thuê một trợ lý lập trình. (Loại 2)" },
    { eng: "If she had reviewed the contract, she would have noticed the error.", vie: "Nếu cô ấy đã xem xét hợp đồng, cô ấy đã nhận ra lỗi. (Loại 3)" },
    { eng: "If the flight is delayed, the schedule will be changed.", vie: "Nếu chuyến bay bị trễ, lịch trình sẽ bị thay đổi." },
    { eng: "If I were the director, I would invest in new servers.", vie: "Nếu tôi là giám đốc, tôi sẽ đầu tư vào các máy chủ mới." },
    { eng: "If they had run tests, they would have found the software bug.", vie: "Nếu họ đã chạy thử nghiệm, họ đã tìm thấy lỗi phần mềm." },
    { eng: "If you have any questions, please contact the front desk.", vie: "Nếu bạn có bất kỳ câu hỏi nào, vui lòng liên hệ bàn lễ tân." },
    { eng: "If she gets the promotion, she will relocate to Seoul.", vie: "Nếu cô ấy được thăng chức, cô ấy sẽ chuyển đến Seoul." },
    { eng: "If he worked harder, he would achieve his sales target.", vie: "Nếu anh ấy làm việc chăm chỉ hơn, anh ấy sẽ đạt được mục tiêu doanh số." },
    { eng: "If the client had rejected the proposal, we would have lost the deal.", vie: "Nếu khách hàng từ chối đề xuất, chúng ta đã mất hợp đồng." },
    { eng: "If you mix blue and yellow, you get green.", vie: "Nếu bạn trộn màu xanh dương và màu vàng, bạn sẽ được màu xanh lá cây." },
    { eng: "If we don't reduce costs, the business will suffer loss.", vie: "Nếu chúng ta không giảm chi phí, doanh nghiệp sẽ chịu tổn thất." },
    { eng: "If I were you, I would back up all files immediately.", vie: "Nếu tôi là bạn, tôi sẽ sao lưu tất cả các tệp ngay lập tức." },
    { eng: "If they had signed earlier, the shipment would have arrived yesterday.", vie: "Nếu họ đã ký sớm hơn, lô hàng đã có thể đến vào ngày hôm qua." },
    { eng: "If the alarm goes off, security guards patrol the area.", vie: "Nếu chuông báo động reo, nhân viên bảo vệ sẽ tuần tra khu vực." },
    { eng: "If we receive the visa on time, we will travel next week.", vie: "Nếu chúng tôi nhận được thị thực đúng hạn, chúng tôi sẽ đi vào tuần tới." },
    { eng: "If the factory had green standards, buyers would purchase more.", vie: "Nếu nhà máy có tiêu chuẩn xanh, người mua sẽ mua nhiều hơn." },
    { eng: "If they had updated the site, users would not have complained.", vie: "Nếu họ đã cập nhật trang web, người dùng đã không phàn nàn." },
    { eng: "If she submits the draft today, I will review it tonight.", vie: "Nếu cô ấy nộp bản thảo hôm nay, tôi sẽ xem xét nó tối nay." }
  ]
};
---

<Layout title="Tổng ôn công thức & 20 ví dụ" description="Tóm tắt công thức ngữ pháp kèm 20 câu ví dụ song ngữ Anh-Việt cho 14 chủ điểm TOEIC.">
  <div class="mb-8">
    <nav class="flex text-sm text-slate-500 mb-4" aria-label="Breadcrumb">
      <a href={import.meta.env.BASE_URL} class="hover:text-blue-600">Trang chủ</a>
      <span class="mx-2">/</span>
      <span class="text-slate-900 dark:text-slate-300 font-medium">Tóm tắt công thức</span>
    </nav>
    <h1 class="text-3xl font-outfit font-bold tracking-tight">Tổng Ôn & Tóm Tắt Ngữ Pháp</h1>
    <p class="text-slate-655 dark:text-slate-400 mt-2">Phần tóm tắt công thức dạng bảng trực quan, loại bỏ Flashcard và bổ sung công cụ làm bài ôn tập 20 câu highlight công thức chi tiết cho từng Module.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
    <!-- Sidebar Navigation -->
    <div class="lg:col-span-1 space-y-2 lg:sticky lg:top-24 h-fit max-h-[80vh] overflow-y-auto pr-2 custom-scrollbar">
      <h3 class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider px-3 mb-3">Danh sách bài học</h3>
      {grammarLessons.map((lesson) => (
        <button 
          class="w-full text-left px-3 py-2 rounded-xl text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800 transition-all truncate unit-nav-btn" 
          data-target={lesson.id.replace(/\.mdx?$/, '')}
        >
          {lesson.data.title}
        </button>
      ))}
    </div>

    <!-- Central Detailed Review Card -->
    <div class="lg:col-span-3 space-y-8">
      {grammarLessons.map((lesson) => {
        const idClean = lesson.id.replace(/\.mdx?$/, '');
        const formulas = lesson.data.formulas || [];
        const sentences = sentenceData[idClean] || [];

        return (
          <div id={`content-${idClean}`} class="unit-content-section p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm space-y-6 hidden">
            <!-- Header -->
            <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-4">
              <div>
                <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 dark:bg-blue-950/30 dark:text-blue-300 mb-3 border border-blue-200 dark:border-blue-800/30">
                  Module {lesson.data.module}
                </div>
                <h2 class="text-2xl sm:text-3xl font-outfit font-bold">{lesson.data.title}</h2>
                <p class="text-slate-655 dark:text-slate-400 text-sm mt-2">{lesson.data.objective}</p>
              </div>
              <button 
                class="px-5 py-3 rounded-xl bg-gradient-to-r from-emerald-600 to-teal-500 hover:from-emerald-700 hover:to-teal-600 text-white font-bold text-sm shadow-md transition-all flex items-center justify-center gap-2 start-review-quiz-btn"
                data-unit={idClean}
                data-title={lesson.data.title}
              >
                <span>📝</span> Làm bài ôn tập 20 câu
              </button>
            </div>

            <hr class="border-slate-150 dark:border-slate-800" />

            <!-- Formulas Table -->
            {formulas.length > 0 && (
              <div class="space-y-3">
                <h3 class="text-lg font-outfit font-bold flex items-center gap-2">
                  <span>📐</span> Bảng cấu trúc công thức cốt lõi
                </h3>
                <div class="overflow-x-auto rounded-xl border border-slate-200 dark:border-slate-850">
                  <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-800 text-sm">
                    <thead class="bg-slate-50 dark:bg-slate-950">
                      <tr>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Dạng / Thể</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Cấu trúc công thức</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Ví dụ minh họa</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-800 bg-white dark:bg-slate-900 font-sans">
                      {formulas.map(f => (
                        <tr>
                          <td class="px-4 py-3 font-semibold text-slate-900 dark:text-slate-100 whitespace-nowrap">{f.label}</td>
                          <td class="px-4 py-3 font-mono text-blue-600 dark:text-blue-400 font-bold">{f.structure}</td>
                          <td class="px-4 py-3 text-slate-600 dark:text-slate-400 italic">{f.example}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            <!-- Usage Summary in Vietnamese -->
            <div class="space-y-3">
              <h3 class="text-lg font-outfit font-bold flex items-center gap-2">
                <span>💡</span> Cách dùng & Dấu hiệu nhận biết
              </h3>
              <div class="p-5 rounded-xl bg-slate-50 dark:bg-slate-950 border border-slate-150 dark:border-slate-850 space-y-3 text-sm text-slate-700 dark:text-slate-300">
                <p>{lesson.data.summary}</p>
                <div class="space-y-2">
                  <p class="font-bold text-xs uppercase tracking-wider text-slate-500">Mẹo ghi nhớ cốt lõi:</p>
                  <ul class="list-disc pl-5 space-y-1.5 text-xs sm:text-sm">
                    {lesson.data.memoryTips.map(tip => (
                      <li>{tip}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>

            <!-- 20 Examples Section -->
            <div class="space-y-4">
              <h3 class="text-lg font-outfit font-bold flex items-center gap-2">
                <span>📚</span> 20 câu ví dụ thực tế song ngữ
              </h3>
              <div class="space-y-3 max-h-[400px] overflow-y-auto pr-2 border border-slate-150 dark:border-slate-800 rounded-xl p-4 bg-slate-50/30 dark:bg-slate-950/20 custom-scrollbar">
                {sentences.map((s, idx) => (
                  <div class="p-3 rounded-lg bg-white dark:bg-slate-900 border border-slate-150 dark:border-slate-800 space-y-1 text-xs sm:text-sm shadow-sm">
                    <div class="flex items-start gap-2">
                      <span class="font-bold text-blue-600 dark:text-blue-400 min-w-[20px]">{idx + 1}.</span>
                      <div class="space-y-0.5">
                        <p class="font-semibold text-slate-800 dark:text-slate-200">EN: {s.eng}</p>
                        <p class="text-slate-655 dark:text-slate-400">VI: {s.vie}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            
            <!-- Details button -->
            <div class="flex justify-end pt-2">
              <a href={`${import.meta.env.BASE_URL}grammar/${idClean}`} class="px-5 py-2.5 rounded-xl border border-slate-200 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-950 text-slate-800 dark:text-slate-200 text-xs font-semibold transition-all">
                Đến bài học đầy đủ & Trắc nghiệm nhanh
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Interactive Quiz Modal -->
  <div id="quiz-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm hidden p-4">
    <div class="w-full max-w-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-xl p-6 sm:p-8 space-y-6 flex flex-col max-h-[90vh]">
      <!-- Modal Header -->
      <div class="flex items-center justify-between">
        <div>
          <span class="text-xs font-bold text-blue-600 dark:text-blue-400 uppercase tracking-wider">Bài ôn tập ngữ pháp</span>
          <h2 id="modal-quiz-title" class="text-xl sm:text-2xl font-outfit font-bold text-slate-900 dark:text-slate-100">Luyện đề 20 câu</h2>
        </div>
        <button id="close-modal-btn" class="p-2 rounded-lg text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-slate-650 transition-all text-xl font-bold">&times;</button>
      </div>

      <!-- Quiz Body wrapper (scrollable) -->
      <div id="modal-quiz-body" class="flex-grow overflow-y-auto space-y-6 pr-2 custom-scrollbar">
        <!-- Progress Bar -->
        <div class="space-y-2">
          <div class="flex justify-between text-xs text-slate-500">
            <span id="modal-progress-text">Câu hỏi 1 / 20</span>
            <span id="modal-score-text">Đúng: 0</span>
          </div>
          <div class="w-full h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
            <div id="modal-progress-bar" class="h-full bg-blue-600 transition-all duration-300" style="width: 5%"></div>
          </div>
        </div>

        <!-- Question text -->
        <div class="p-5 rounded-xl bg-slate-50 dark:bg-slate-950 border border-slate-150 dark:border-slate-850">
          <p id="modal-question-text" class="text-base font-semibold text-slate-800 dark:text-slate-200 leading-relaxed"></p>
        </div>

        <!-- Options buttons -->
        <div id="modal-options-container" class="grid grid-cols-1 gap-3"></div>

        <!-- Explanation card (with highlighted formula) -->
        <div id="modal-explanation-card" class="p-5 rounded-xl bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 space-y-2 hidden">
          <p id="modal-correct-label" class="font-bold text-emerald-600 dark:text-emerald-400 text-sm"></p>
          <div id="modal-explanation-text" class="text-xs sm:text-sm text-slate-650 dark:text-slate-300 leading-relaxed space-y-3"></div>
        </div>
      </div>

      <!-- Modal Footer -->
      <div class="flex justify-end gap-3 pt-4 border-t border-slate-150 dark:border-slate-800">
        <button id="modal-next-btn" class="px-5 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm transition-all hidden">Câu tiếp theo</button>
        <button id="modal-finish-btn" class="px-5 py-2.5 rounded-xl bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 font-semibold text-sm transition-all hidden">Hoàn thành</button>
      </div>
    </div>
  </div>

  <!-- Interactive page logic script -->
  <script is:inline>
    // Generative 20-question review pool generator per Unit
    // Highlighted formulas are placed inside standard <span class="px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30">
    const reviewQuestionsData = {
      "unit-1": [
        { q: "The security supervisor _____ the building gates every night at 10 PM.", o: ["is locking", "locks", "locked", "has locked"], a: "locks", e: "Từ chỉ tần suất 'every night' báo hiệu hành động lặp đi lặp lại thường xuyên ở hiện tại. Sử dụng công thức Hiện tại đơn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + V(s/es)</span>. Vì chủ ngữ 'security supervisor' số ít nên chọn 'locks'." },
        { q: "We _____ our customer database server at the moment.", o: ["are upgrading", "upgrade", "upgraded", "have upgraded"], a: "are upgrading", e: "Cụm từ 'at the moment' (ngay lúc này) báo hiệu hành động đang xảy ra tại thời điểm nói. Sử dụng công thức Hiện tại tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + am/is/are + V-ing</span>." },
        { q: "The flight to Tokyo _____ from gate 4 at 9:00 AM tomorrow.", o: ["is departing", "departs", "departed", "has departed"], a: "departs", e: "Khi nói về lịch trình cố định của phương tiện giao thông, lịch bay, lịch tàu chạy, ta ưu tiên sử dụng Hiện tại đơn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + V(s/es)</span> diễn đạt tương lai." },
        { q: "Water _____ at 100 degrees Celsius under standard atmospheric pressure.", o: ["boil", "is boiling", "boils", "boiled"], a: "boils", e: "Đây là một sự thật hiển nhiên hoặc định luật vật lý. Dùng Hiện tại đơn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + V(s/es)</span>." },
        { q: "The executive team _____ with foreign delegates in the main lobby currently.", o: ["meets", "is meeting", "met", "has met"], a: "is meeting", e: "Từ nhận biết 'currently' báo hiệu hành động đang tiếp diễn ở hiện tại. Sử dụng Hiện tại tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + am/is/are + V-ing</span>." },
        { q: "Ms. Harrison _____ to Singapore three times a year to inspect the branch.", o: ["is traveling", "travels", "traveled", "has traveled"], a: "travels", e: "Cụm trạng từ chỉ tần suất 'three times a year' chỉ một thói quen, chu kỳ lặp lại. Sử dụng Hiện tại đơn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + V(s/es)</span>." },
        { q: "Look! The main technicians _____ the server racks in Room 102.", o: ["repair", "are repairing", "repaired", "have repaired"], a: "are repairing", e: "Từ hô cảm 'Look!' yêu cầu người nghe chú ý vào một hành động đang trực tiếp tiếp diễn trước mắt. Dùng Hiện tại tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + am/is/are + V-ing</span>." },
        { q: "Our corporation regularly _____ fresh agricultural products to European countries.", o: ["is exporting", "exports", "exported", "has exported"], a: "exports", e: "Trạng từ 'regularly' (thường xuyên) thể hiện một chu kỳ lặp lại cố định. Dùng Hiện tại đơn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + V(s/es)</span>." },
        { q: "She _____ the client's product preferences very well after years of partnership.", o: ["is knowing", "knows", "knowed", "has known"], a: "knows", e: "Động từ trạng thái (Stative verbs) như 'know', 'believe', 'understand' không chia ở dạng tiếp diễn. Dùng Hiện tại đơn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + V(s/es)</span>." },
        { q: "The new retail branch _____ next Tuesday at 8:00 AM.", o: ["is opening", "opens", "opened", "has opened"], a: "opens", e: "Lịch trình khai trương có thời gian cố định sử dụng tương lai theo lịch trình cố định. Dùng Hiện tại đơn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + V(s/es)</span>." },
        { q: "The accounting department _____ a comprehensive internal review this week.", o: ["conducts", "is conducting", "conducted", "has conducted"], a: "is conducting", e: "Từ nhận biết 'this week' báo hiệu một công việc tạm thời đang diễn ra trong tuần này. Dùng Hiện tại tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + am/is/are + V-ing</span>." },
        { q: "The office manager always _____ the storage locker before leaving.", o: ["checks", "is checking", "checked", "has checked"], a: "checks", e: "Trạng từ 'always' thể hiện một thói quen cố định. Sử dụng Hiện tại đơn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + V(s/es)</span>." },
        { q: "Why _____ you _____ the operating system of your work computer today?", o: ["are/upgrading", "do/upgrade", "did/upgrade", "have/upgraded"], a: "are/upgrading", e: "Từ chỉ thời gian 'today' trong trường hợp này hỏi về hành động tạm thời đang làm trong ngày hôm nay. Dùng Hiện tại tiếp diễn dạng câu hỏi: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>Am/Is/Are + S + V-ing?</span>." },
        { q: "The training workshop _____ in ten minutes, so please take your seats.", o: ["is starting", "starts", "started", "has started"], a: "starts", e: "Sự kiện được lên lịch trình sẵn trong tương lai gần. Dùng Hiện tại đơn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + V(s/es)</span>." },
        { q: "Online sales of our products _____ rapidly this current quarter.", o: ["increase", "are increasing", "increased", "have increased"], a: "are increasing", e: "Mô tả một xu hướng biến động tạm thời trong quý này. Dùng Hiện tại tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + am/is/are + V-ing</span>." },
        { q: "This document folder _____ to the legal department on the third floor.", o: ["is belonging", "belongs", "belonged", "has belonged"], a: "belongs", e: "Động từ 'belong' là động từ trạng thái thể hiện quyền sở hữu, không được dùng dạng tiếp diễn. Dùng Hiện tại đơn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + V(s/es)</span>." },
        { q: "My direct supervisor _____ the final drafts of the sales agreement.", o: ["is checking", "checks", "checked", "has checked"], a: "is checking", e: "Mô tả hành động đang kiểm tra bản thảo diễn ra ở hiện tại. Chọn Hiện tại tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + am/is/are + V-ing</span>." },
        { q: "We _____ for an experienced tax accountant temporarily this month.", o: ["look", "are looking", "looked", "have looked"], a: "are looking", e: "Trạng từ 'temporarily' (tạm thời) chỉ một tình huống tạm thời. Dùng Hiện tại tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + am/is/are + V-ing</span>." },
        { q: "Generally, the store clerk _____ the register at the end of the shift.", o: ["is closing", "closes", "closed", "has closed"], a: "closes", e: "Trạng từ 'Generally' (Thông thường) báo hiệu quy trình lặp đi lặp lại. Dùng Hiện tại đơn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + V(s/es)</span>." },
        { q: "The client _____ our terms of agreement at the moment.", o: ["questions", "is questioning", "questioned", "has questioned"], a: "is questioning", e: "Từ nhận biết 'at the moment' yêu cầu chia động từ ở Hiện tại tiếp diễn: <span class='px-1.5 py-0.5 rounded font-mono font-bold bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 border border-blue-200 dark:border-blue-800/30'>S + am/is/are + V-ing</span>." }
