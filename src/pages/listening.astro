---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const listeningLessons = await getCollection('listening');
---

<Layout title="Lộ trình luyện nghe TOEIC" description="Danh sách các bài học luyện nghe TOEIC từ Part 1 đến Part 4.">
  <div class="mb-8">
    <nav class="flex text-sm text-slate-500 mb-4" aria-label="Breadcrumb">
      <a href="/" class="hover:text-blue-600">Trang chủ</a>
      <span class="mx-2">/</span>
      <span class="text-slate-900 dark:text-slate-300 font-medium">Luyện nghe</span>
    </nav>
    <h1 class="text-3xl font-outfit font-bold tracking-tight">Lộ Trình Luyện Nghe TOEIC</h1>
    <p class="text-slate-600 dark:text-slate-400 mt-2">Phát triển phản xạ nghe hiểu từ Part 1 đến Part 4.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {listeningLessons.map(lesson => (
      <a href={`/listening/${lesson.id.replace(/\.mdx?$/, '')}`} class="block group p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-blue-500 dark:hover:border-blue-500 hover:shadow-lg transition-all">
        <div class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-2">Module {lesson.data.module}</div>
        <h2 class="text-xl font-outfit font-bold group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors mb-2">{lesson.data.title}</h2>
        <p class="text-slate-600 dark:text-slate-400 text-sm line-clamp-2 mb-4">{lesson.data.objective}</p>
        <div class="flex items-center text-sm font-medium text-blue-600 dark:text-blue-400 group-hover:translate-x-1 transition-transform">
          Bắt đầu học
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </div>
      </a>
    ))}
  </div>
</Layout>
