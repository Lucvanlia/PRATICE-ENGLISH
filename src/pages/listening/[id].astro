---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const listeningLessons = await getCollection('listening');
  return listeningLessons.map(lesson => ({
    params: { id: lesson.id.replace(/\.mdx?$/, '') },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const { Content } = await render(lesson);
const { data } = lesson;
---

<Layout title={data.title} description={data.objective}>
  <nav class="flex text-sm text-slate-500 mb-6" aria-label="Breadcrumb">
    <a href={import.meta.env.BASE_URL} class="hover:text-blue-600">Trang chủ</a>
    <span class="mx-2">/</span>
    <a href={`${import.meta.env.BASE_URL}listening`} class="hover:text-blue-600">Luyện nghe</a>
    <span class="mx-2">/</span>
    <span class="text-slate-900 dark:text-slate-300 font-medium truncate max-w-[200px] sm:max-w-none">{data.title}</span>
  </nav>

  <div class="mb-8">
    <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 dark:bg-blue-950/30 dark:text-blue-300 mb-3 border border-blue-200 dark:border-blue-800/30">
      Module {data.module}
    </div>
    <h1 class="text-3xl sm:text-4xl font-outfit font-bold tracking-tight">{data.title}</h1>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left column: Objective, Visual and Theory -->
    <div class="lg:col-span-2 space-y-8">
      <!-- Objective Card -->
      <div class="p-6 rounded-2xl bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-slate-900 dark:to-slate-900 border border-blue-100 dark:border-slate-800">
        <h3 class="text-lg font-outfit font-semibold text-blue-900 dark:text-blue-100 mb-2">Mục tiêu bài học</h3>
        <p class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed">{data.objective}</p>
      </div>

      <!-- Visual Explanation -->
      {data.visualExplanation && (
        <div class="p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 space-y-3">
          <h3 class="text-lg font-outfit font-semibold mb-3">Tóm tắt tư duy</h3>
          <ul class="space-y-2.5">
            {data.visualExplanation.map(point => (
              <li class="flex items-start text-sm text-slate-700 dark:text-slate-300">
                <svg class="w-4 h-4 text-blue-500 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path></svg>
                {point}
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Theory Content -->
      <article class="p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 prose dark:prose-invert max-w-none prose-sm sm:prose-base prose-headings:font-outfit">
        <Content />
      </article>

      <!-- Examples Section with Speaker Buttons -->
      <div class="p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
        <h3 class="text-xl font-outfit font-bold mb-4">Ví dụ thực tế</h3>
        <div class="space-y-4">
          {data.examples.map(ex => (
            <div class="p-4 rounded-xl bg-slate-50 dark:bg-slate-950 border border-slate-100 dark:border-slate-850 flex justify-between items-start gap-4">
              <div class="space-y-1 flex-grow">
                <p class="text-sm font-semibold text-blue-600 dark:text-blue-400">EN: {ex.eng}</p>
                <p class="text-sm text-slate-655 dark:text-slate-400">VI: {ex.vie}</p>
                {ex.note && <p class="text-xs text-slate-500 dark:text-slate-500 italic mt-2">💡 Ghi chú: {ex.note}</p>}
              </div>
              <button class="play-audio-btn p-2 rounded-lg bg-blue-50 dark:bg-blue-950/45 text-blue-600 dark:text-blue-300 hover:ring-2 hover:ring-blue-500 flex-shrink-0 transition-all text-sm" data-text={ex.eng} title="Nghe câu này">
                🔊 Phát âm
              </button>
            </div>
          ))}
        </div>
      </div>

      <!-- Common Mistakes Section -->
      <div class="p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
        <h3 class="text-xl font-outfit font-bold mb-4">Bẫy & Lỗi sai thường gặp</h3>
        <div class="space-y-4">
          {data.commonMistakes.map(m => (
            <div class="p-4 rounded-xl bg-red-50/50 dark:bg-red-950/10 border border-red-100 dark:border-red-900/30">
              <div class="text-sm text-red-600 dark:text-red-400 line-through">Bẫy: {m.mistake}</div>
              <div class="text-sm text-emerald-600 dark:text-emerald-400 font-semibold mt-1">Cách tránh bẫy: {m.correction}</div>
              <p class="text-xs text-slate-655 dark:text-slate-450 mt-2">👉 Giải thích bẫy: {m.explanation}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Right column: Audio Controller Widget, Memory Tips, Quiz and Homework -->
    <div class="space-y-8">
      <!-- TTS Controller Panel -->
      <div class="p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 space-y-4">
        <h3 class="text-lg font-outfit font-bold flex items-center gap-2">
          <span>🎧</span> Bảng điều khiển giọng đọc
        </h3>
        <div class="space-y-3 text-xs sm:text-sm">
          <div class="space-y-1">
            <label class="font-semibold text-slate-500">Giọng đọc (Voice):</label>
            <select id="tts-voice-select" class="w-full p-2 rounded-lg border border-slate-250 dark:border-slate-700 bg-slate-50 dark:bg-slate-950 font-sans"></select>
          </div>
          <div class="space-y-1">
            <label class="font-semibold text-slate-500">Tốc độ đọc (Speed):</label>
            <div class="grid grid-cols-3 gap-2" id="tts-speed-container">
              <button class="tts-rate-btn p-1.5 rounded-lg border border-slate-200 dark:border-slate-700 text-xs font-semibold hover:bg-slate-100 dark:hover:bg-slate-800 transition-all" data-rate="0.75">Chậm (0.75x)</button>
              <button class="tts-rate-btn p-1.5 rounded-lg border border-blue-500 bg-blue-50 text-blue-700 dark:bg-blue-950/20 dark:text-blue-300 text-xs font-bold transition-all" data-rate="1">Thường (1.0x)</button>
              <button class="tts-rate-btn p-1.5 rounded-lg border border-slate-200 dark:border-slate-700 text-xs font-semibold hover:bg-slate-100 dark:hover:bg-slate-800 transition-all" data-rate="1.2">Nhanh (1.2x)</button>
            </div>
          </div>
          <div id="tts-visualizer" class="hidden items-center justify-center gap-2 py-2 border-t border-slate-100 dark:border-slate-800">
            <span class="text-xs text-slate-500 animate-pulse">Đang đọc âm thanh...</span>
            <div class="flex gap-1 items-end h-4">
              <span class="w-1 bg-blue-500 rounded animate-wave h-2" style="animation-delay: 0.1s"></span>
              <span class="w-1 bg-blue-500 rounded animate-wave h-3.5" style="animation-delay: 0.3s"></span>
              <span class="w-1 bg-blue-500 rounded animate-wave h-1.5" style="animation-delay: 0.5s"></span>
              <span class="w-1 bg-blue-500 rounded animate-wave h-3" style="animation-delay: 0.7s"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Memory Tips -->
      <div class="p-6 rounded-2xl bg-amber-50/50 dark:bg-amber-950/10 border border-amber-100 dark:border-amber-900/20">
        <h3 class="text-lg font-outfit font-bold text-amber-900 dark:text-amber-300 mb-3">Mẹo ghi nhớ</h3>
        <ul class="space-y-2">
          {data.memoryTips.map(tip => (
            <li class="flex items-start text-sm text-slate-700 dark:text-slate-400">
              <span class="mr-2 text-amber-500">⭐️</span>
              {tip}
            </li>
          ))}
        </ul>
      </div>

      <!-- Quiz Engine with Speaker Icon -->
      <div class="p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
        <h3 class="text-lg font-outfit font-bold mb-4">Trắc nghiệm nhanh</h3>
        <div class="space-y-6">
          {data.miniQuiz.map((q, qIndex) => (
            <div class="quiz-block space-y-3" data-correct={q.answer} data-index={qIndex}>
              <div class="flex justify-between items-start gap-2">
                <p class="text-sm font-semibold text-slate-800 dark:text-slate-200 flex-grow">Q{qIndex + 1}: {q.question}</p>
                <button class="play-audio-btn p-1.5 rounded bg-slate-100 dark:bg-slate-800 hover:ring-2 hover:ring-blue-500 text-xs flex-shrink-0 transition-all" data-text={q.question} title="Nghe câu hỏi">
                  🔊 Nghe
                </button>
              </div>
              <div class="space-y-2">
                {q.options.map(opt => (
                  <button class="w-full text-left p-3 text-xs sm:text-sm rounded-xl border border-slate-200 dark:border-slate-800 hover:border-blue-500 hover:bg-blue-50/10 transition-all quiz-option" data-option={opt}>
                    {opt}
                  </button>
                ))}
              </div>
              <div class="quiz-explanation hidden p-3 rounded-xl bg-slate-50 dark:bg-slate-950 border border-slate-150 dark:border-slate-850 text-xs mt-3">
                <p class="font-bold text-emerald-600 dark:text-emerald-400">Đáp án: {q.answer}</p>
                <p class="text-slate-650 dark:text-slate-400 mt-1">{q.explanation}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Homework -->
      <div class="p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
        <h3 class="text-lg font-outfit font-bold mb-3">Bài tập tự luyện</h3>
        <div class="space-y-4">
          {data.homework.map((hw, idx) => (
            <div class="space-y-2">
              <div class="flex justify-between items-start gap-2">
                <p class="text-sm text-slate-800 dark:text-slate-200 flex-grow">Ex {idx + 1}: {hw.question}</p>
                <button class="play-audio-btn p-1.5 rounded bg-slate-100 dark:bg-slate-800 hover:ring-2 hover:ring-blue-500 text-xs flex-shrink-0 transition-all" data-text={hw.question} title="Nghe">
                  🔊
                </button>
              </div>
              <details class="group">
                <summary class="list-none flex items-center gap-1 text-xs font-semibold text-blue-600 dark:text-blue-400 cursor-pointer select-none">
                  <span>Hiện đáp án</span>
                  <svg class="w-3.5 h-3.5 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </summary>
                <div class="p-3 mt-2 rounded-xl bg-slate-50 dark:bg-slate-950 border border-slate-150 dark:border-slate-850 text-xs text-slate-700 dark:text-slate-300">
                  {hw.answer}
                </div>
              </details>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Interactive script -->
  <script is:inline>
    // TTS Audio Player Engine
    let currentRate = 1.0;
    let selectedVoiceName = '';

    const voiceSelect = document.getElementById('tts-voice-select');
    const visualizer = document.getElementById('tts-visualizer');
    const playBtns = document.querySelectorAll('.play-audio-btn');

    // Populate English voices
    function populateVoices() {
      if (typeof window === 'undefined' || !window.speechSynthesis) return;
      
      const voices = window.speechSynthesis.getVoices();
      const englishVoices = voices.filter(v => v.lang.startsWith('en-'));
      
      voiceSelect.innerHTML = '';
      if (englishVoices.length === 0) {
        const opt = document.createElement('option');
        opt.textContent = "Hệ thống mặc định (Default English)";
        opt.value = "";
        voiceSelect.appendChild(opt);
        return;
      }

      englishVoices.forEach(voice => {
        const opt = document.createElement('option');
        opt.value = voice.name;
        opt.textContent = `${voice.name} (${voice.lang})`;
        voiceSelect.appendChild(opt);
      });

      // Default to Google US English or Microsoft Zira if available
      const primaryVoice = englishVoices.find(v => v.name.includes('Google US English') || v.name.includes('Natural') || v.name.includes('Zira'));
      if (primaryVoice) {
        voiceSelect.value = primaryVoice.name;
        selectedVoiceName = primaryVoice.name;
      } else {
        selectedVoiceName = englishVoices[0].name;
      }
    }

    if (typeof window !== 'undefined' && window.speechSynthesis) {
      window.speechSynthesis.onvoiceschanged = populateVoices;
      populateVoices();
    }

    voiceSelect?.addEventListener('change', () => {
      selectedVoiceName = voiceSelect.value;
    });

    // Speed button click handler
    const rateBtns = document.querySelectorAll('.tts-rate-btn');
    rateBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        rateBtns.forEach(b => {
          b.classList.remove('border-blue-500', 'bg-blue-50', 'text-blue-700', 'dark:bg-blue-950/20', 'dark:text-blue-300', 'font-bold');
          b.classList.add('border-slate-200', 'dark:border-slate-700', 'font-semibold');
        });
        btn.classList.remove('border-slate-200', 'dark:border-slate-700', 'font-semibold');
        btn.classList.add('border-blue-500', 'bg-blue-50', 'text-blue-700', 'dark:bg-blue-950/20', 'dark:text-blue-300', 'font-bold');
        currentRate = parseFloat(btn.getAttribute('data-rate'));
      });
    });

    // Play function
    function playText(text) {
      if (typeof window === 'undefined' || !window.speechSynthesis) {
        alert("Trình duyệt của bạn không hỗ trợ công cụ phát âm thanh (Speech Synthesis).");
        return;
      }

      window.speechSynthesis.cancel(); // Stop current speech

      // Remove parenthesis and brackets from reading text to keep speech clean
      const cleanText = text.replace(/\([^)]*\)/g, '').replace(/\[[^\]]*\]/g, '').replace(/_/g, ' blank ').trim();

      const utterance = new SpeechSynthesisUtterance(cleanText);
      utterance.rate = currentRate;
      utterance.lang = 'en-US';

      const voices = window.speechSynthesis.getVoices();
      const activeVoice = voices.find(v => v.name === selectedVoiceName);
      if (activeVoice) {
        utterance.voice = activeVoice;
      }

      utterance.onstart = () => {
        visualizer?.classList.remove('hidden');
        visualizer?.classList.add('flex');
      };

      utterance.onend = () => {
        visualizer?.classList.add('hidden');
        visualizer?.classList.remove('flex');
      };

      utterance.onerror = () => {
        visualizer?.classList.add('hidden');
        visualizer?.classList.remove('flex');
      };

      window.speechSynthesis.speak(utterance);
    }

    playBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const text = btn.getAttribute('data-text');
        if (text) {
          playText(text);
        }
      });
    });

    // Quiz logic
    const quizBlocks = document.querySelectorAll('.quiz-block');
    quizBlocks.forEach(block => {
      const correctAnswer = block.getAttribute('data-correct');
      const options = block.querySelectorAll('.quiz-option');
      const explanation = block.querySelector('.quiz-explanation');

      options.forEach(opt => {
        opt.addEventListener('click', () => {
          const selectedVal = opt.getAttribute('data-option');
          
          // Disable all options in this block
          options.forEach(btn => {
            btn.disabled = true;
            if (btn.getAttribute('data-option') === correctAnswer) {
              btn.classList.add('bg-emerald-50', 'border-emerald-500', 'text-emerald-700', 'dark:bg-emerald-950/20', 'dark:border-emerald-800', 'dark:text-emerald-300');
            }
          });

          if (selectedVal !== correctAnswer) {
            opt.classList.add('bg-red-50', 'border-red-500', 'text-red-700', 'dark:bg-red-950/20', 'dark:border-red-800', 'dark:text-red-300');
          }

          explanation?.classList.remove('hidden');
        });
      });
    });
  </script>

  <style>
    @keyframes wave {
      0%, 100% { height: 4px; }
      50% { height: 16px; }
    }
    .animate-wave {
      animation: wave 1s ease-in-out infinite;
    }
  </style>
</Layout>
